# Copy this file to .env (for local dev with `vercel dev`) and fill in real values.
# In production, set these as Environment Variables in the Vercel dashboard instead
# (Project Settings → Environment Variables). NEVER commit real secrets to git.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key-KEEP-SECRET
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather-KEEP-SECRET
